SANTISZR_APP_NAME=SantiSZR
SANTISZR_APP_ENV=development
SANTISZR_DEBUG=false
SANTISZR_LOG_LEVEL=INFO
SANTISZR_LOG_FORMAT=text
SANTISZR_DATA_DIR=
SANTISZR_CACHE_DIR=
SANTISZR_LOG_DIR=
SANTISZR_MAIN_WINDOW__TITLE=SantiSZR
SANTISZR_MAIN_WINDOW__WIDTH=1280
SANTISZR_MAIN_WINDOW__HEIGHT=800

SANTISZR_MODEL_ROOT=D:\SantiSZR\models
SANTISZR_VOXCPM_MODEL_DIR=D:\SantiSZR\models\voxcpm\VoxCPM2
SANTISZR_WHISPER_MODEL_DIR=D:\SantiSZR\models\whisper
SANTISZR_TUILIONNX_MODEL_DIR=D:\SantiSZR\models\tuilionnx
SANTISZR_TUILIONNX_ROOT=
SANTISZR_TUILIONNX_PYTHON=
SANTISZR_TUILIONNX_DEFAULT_MODEL=default-avatar

SANTISZR_FFMPEG_PATH=
SANTISZR_FFPROBE_PATH=

SANTISZR_SUBTITLE_SCRIPT=
SANTISZR_SUBTITLE_PYTHON=

SANTISZR_TTS_PROVIDER=voxcpm2
SANTISZR_TTS_MODEL_NAME=VoxCPM2
SANTISZR_TTS_BASE_URL=http://127.0.0.1:9880
SANTISZR_TTS_TIMEOUT_SEC=120
SANTISZR_TTS_DEFAULT_VOICE=reference-clone
SANTISZR_TTS_HEALTH_PATH=/health
SANTISZR_TTS_STARTUP_TIMEOUT_SEC=30
SANTISZR_TTS_STARTUP_COMMAND=
SANTISZR_VOXCPM_PYTHON=D:\SantiSZR\tools\voxcpm_python\python.exe
SANTISZR_TTS_VOXCPM_CFG_VALUE=2.0
SANTISZR_TTS_VOXCPM_INFERENCE_TIMESTEPS=10
SANTISZR_TTS_VOXCPM_RETRY_BADCASE=true
SANTISZR_TTS_PROMPT_MAX_SECONDS=29.5

# Optional / legacy CosyVoice compatibility
SANTISZR_COSYVOICE_MODEL_DIR=D:\SantiSZR\models\cosyvoice

SANTISZR_LLM_API_KEY=
DEEPSEEK_API_KEY=
SANTISZR_LLM_API_BASE=https://api.deepseek.com/v1
SANTISZR_LLM_MODEL=deepseek-chat
SANTISZR_LLM_TIMEOUT_SEC=60

SANTISZR_PUBLISH_PYTHON=
SANTISZR_EXTERNAL_PUBLISHER_ROOT=
